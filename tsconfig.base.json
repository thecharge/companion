{
  "compilerOptions": {
    "target":            "ESNext",
    "module":            "ESNext",
    "moduleResolution":  "bundler",
    "lib":               ["ESNext"],
    "types":             ["bun-types"],
    "strict":            true,
    "exactOptionalPropertyTypes": false,
    "skipLibCheck":      true,
    "jsx":               "react-jsx",
    "jsxImportSource":   "react",
    "resolveJsonModule": true,
    "noEmit":            true
  }
}

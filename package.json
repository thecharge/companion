{
  "name": "companion",
  "version": "0.0.1",
  "private": true,
  "packageManager": "bun@1.3.10",
  "workspaces": ["packages/*", "apps/*"],
  "scripts": {
    "prepare": "bash scripts/setup-hooks.sh",
    "dev": "turbo run dev --concurrency=10",
    "build": "turbo run build",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "lint": "biome check .",
    "format": "biome format --write .",
    "server": "bun run apps/server/src/index.ts",
    "tui": "bun run apps/tui/src/index.tsx",
    "pull": "bun run scripts/pull.ts",
    "readiness": "bash scripts/readiness-check.sh",
    "webhook:smoke": "bash scripts/webhook-smoke.sh",
    "proof:runtime": "bun run scripts/runtime-proof.ts",
    "proof:providers": "bun run scripts/provider-proof.ts",
    "proof:db": "bun run scripts/db-proof.ts",
    "build:tui:exe": "bash scripts/build-tui-executable.sh",
    "install:cli": "bash scripts/install-cli.sh",
    "uninstall:cli": "bash scripts/uninstall-cli.sh"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "bun-types": "1.1.42",
    "turbo": "2.9.4",
    "typescript": "5.7.2"
  }
}

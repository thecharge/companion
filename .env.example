# Core server
COMPANION_SECRET=change-me-in-production
COMPANION_PORT=3000
# DB-backed audit is the default and only mode currently.
AUDIT_LOG_DEFAULT_LIMIT=250
AUDIT_LOG_MAX_LIMIT=10000

# Optional TUI/API endpoint override
# If set, TUI prefers this full URL over host/port derivation.
COMPANION_URL=

# Database (leave blank to use SQLite)
DATABASE_URL=

# Ollama (default local provider endpoint)
OLLAMA_BASE_URL=http://localhost:11434

# LLM providers (set only what you use)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
GROK_API_KEY=

# Optional GitHub token for provider/tooling flows that need it
GITHUB_TOKEN=

# Sandbox runtime
# one of: auto | docker | podman | nerdctl | direct
COMPANION_SANDBOX_RUNTIME=auto

# MCP server catalog
MCP_ENABLED=false
MCP_SERVER_FILESYSTEM_ENABLED=false
MCP_SERVER_FETCH_ENABLED=false

# Slack integration
SLACK_ENABLED=false
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_REQUIRED_PASSPHRASE=
SLACK_MODE=balanced

# Telegram integration
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_SECRET_TOKEN=
TELEGRAM_REQUIRED_PASSPHRASE=
TELEGRAM_MODE=balanced
